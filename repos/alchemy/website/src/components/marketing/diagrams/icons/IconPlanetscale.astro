---
import { PS_COLOR, tint } from "../_colors";
interface Props { size?: number; color?: string }
const { size = 26, color = PS_COLOR } = Astro.props;
const fill = tint(color);
---
<svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true">
  <circle cx="16" cy="16" r="11" fill={fill} stroke={color} stroke-width="1.5" />
  <path
    d="M16 5 A11 11 0 0 1 27 16 L16 16 Z"
    fill={color}
    opacity="0.85"
  />
  <circle cx="16" cy="16" r="3.2" fill="var(--alc-bg-code)" stroke={color} stroke-width="1.2" />
</svg>
