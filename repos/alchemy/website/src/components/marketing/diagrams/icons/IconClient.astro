  <circle cx="16" cy="16" r="11" stroke="var(--alc-fg-3)" stroke-width="1.4" />
  <ellipse cx="16" cy="16" rx="5" ry="11" stroke="var(--alc-fg-3)" stroke-width="1.2" />
  <line x1="5" y1="16" x2="27" y2="16" stroke="var(--alc-fg-3)" stroke-width="1.2" />
</svg>
