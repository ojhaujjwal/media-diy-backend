---
const accent = "var(--alc-accent-deep)";
---

<svg viewBox="0 0 280 130" width="100%" height="100%" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
  <!-- Browser chrome -->
  <g transform="translate(40 22)">
    <rect width="200" height="80" rx="8" fill="var(--alc-bg-elev-1)" stroke="var(--alc-hairline-2)" stroke-width="1" />
    <circle cx="10" cy="10" r="2.4" fill="var(--alc-danger)" />
    <circle cx="18" cy="10" r="2.4" fill="var(--alc-warn)" />
    <circle cx="26" cy="10" r="2.4" fill="var(--alc-accent-bright)" />
    <rect x="36" y="5" width="158" height="11" rx="5" fill="var(--alc-bg)" stroke="var(--alc-hairline-2)" stroke-width="0.8" />
    <text x="44" y="13" font-family="var(--alc-font-mono)" font-size="7" fill="var(--alc-fg-3)">https://app.workers.dev</text>

    <!-- mock page content with framework dots -->
    <rect x="14" y="26" width="172" height="6" rx="2" fill={accent} opacity="0.85" />
    <rect x="14" y="38" width="120" height="4" rx="2" fill="var(--alc-fg-3)" opacity="0.5" />
    <rect x="14" y="48" width="146" height="4" rx="2" fill="var(--alc-fg-3)" opacity="0.45" />
    <rect x="14" y="58" width="100" height="4" rx="2" fill="var(--alc-fg-3)" opacity="0.4" />

    <!-- framework brand dots -->
    <circle cx="148" cy="64" r="3" fill="#FF6154" />
    <circle cx="158" cy="64" r="3" fill="#FF5D01" />
    <circle cx="168" cy="64" r="3" fill="#00DC82" />
    <circle cx="178" cy="64" r="3" fill="#61DAFB" />
  </g>

  <!-- caption -->
  <text x="140" y="118" text-anchor="middle" font-family="var(--alc-font-hand)" font-size="13" fill={accent} font-style="italic">
    Vite · TanStack · Astro · React · Hugo
  </text>
</svg>
