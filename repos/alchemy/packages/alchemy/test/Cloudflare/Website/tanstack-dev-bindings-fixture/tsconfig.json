{
  "include": [
    "alchemy.run.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "moduleDetection": "force",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["bun", "vite/client", "@cloudflare/workers-types"]
  }
}
