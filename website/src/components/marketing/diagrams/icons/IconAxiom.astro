---
import { AXIOM_COLOR, tint } from "../_colors";
interface Props { size?: number; color?: string }
const { size = 26, color = AXIOM_COLOR } = Astro.props;
const fill = tint(color);
---
<svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true">
  <rect x="4" y="4" width="24" height="24" rx="5" fill={fill} stroke={color} stroke-width="1.5" />
  <path d="M9 22 L16 9 L23 22" stroke={color} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none" />
  <path d="M12 18 L20 18" stroke={color} stroke-width="1.4" stroke-linecap="round" />
</svg>
