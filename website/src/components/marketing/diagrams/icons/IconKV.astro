---
import { CF_COLOR, tint } from "../_colors";
interface Props { size?: number; color?: string }
const { size = 26, color = CF_COLOR } = Astro.props;
const fill = tint(color);
---
<svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true">
  <circle cx="11" cy="16" r="6" fill={fill} stroke={color} stroke-width="1.5" />
  <circle cx="11" cy="16" r="2.2" fill={color} />
  <path d="M17 16 L27 16 M23 16 L23 21 M27 16 L27 12" stroke={color} stroke-width="1.5" stroke-linecap="round" />
</svg>
