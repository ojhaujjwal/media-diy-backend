{
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.output/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/coverage/**",
    "**/repos/**",
    "**/*.gen.ts",
    "**/*.gen.tsx",
    "**/*.md",
    "**/bin/**"
  ],
  "jsPlugins": ["./lint/index.ts"],
  "rules": {
    "typescript/no-explicit-any": "error",
    "typescript/consistent-type-assertions": ["error", { "assertionStyle": "never" }],
    "typescript/consistent-type-imports": "error",
    "typescript/no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "eslint/prefer-const": "error",
    "eslint/object-shorthand": "error",
    "eslint/no-redeclare": "off",
    "media-diy/no-disable-validation": "error",
    "media-diy/pipe-max-arguments": "error",
    "media-diy/no-nested-layer-provide": "error",
    "media-diy/no-service-option": "error",
    "media-diy/no-void-expression": "error",
    "media-diy/no-effect-ignore": "error",
    "media-diy/no-effect-catchallcause": "error",
    "media-diy/no-effect-asvoid": "error",
    "media-diy/no-silent-error-swallow": "error",
    "media-diy/no-satisfies": "error",
    "media-diy/no-oxlint-disable": "error",
    "media-diy/no-effect-any": "error",
    "media-diy/no-async-await": "error",
    "media-diy/no-process": "error"
  },
  "overrides": [
    {
      "files": ["src/infrastructure/persistence/media-contents.r2.ts"],
      "rules": {
        "media-diy/no-process": "off"
      }
    },
    {
      "files": ["tests/integration/fixtures/stack.ts"],
      "rules": {
        "media-diy/no-process": "off"
      }
    },
    {
      "files": ["tests/integration/presigned-url.integration.test.ts"],
      "rules": {
        "media-diy/no-process": "off"
      }
    },
    {
      "files": ["tests/integration/rpc-smoke.integration.test.ts"],
      "rules": {
        "media-diy/no-process": "off"
      }
    },
    {
      "files": ["tests/integration/search-media.integration.test.ts"],
      "rules": {
        "media-diy/no-process": "off"
      }
    },
    {
      "files": ["tests/integration/fast-scan.integration.test.ts"],
      "rules": {
        "media-diy/no-process": "off"
      }
    },
    {
      "files": ["vitest.config.ts"],
      "rules": {
        "media-diy/no-process": "off"
      }
    }
  ]
}
