{
  "name": "ts-starter",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:types": "vitest run --typecheck",
    "test:integration": "INTEGRATION=1 vitest run tests/integration",
    "typecheck": "tsc --noEmit",
    "dev": "alchemy dev",
    "deploy": "alchemy deploy",
    "lint": "NODE_OPTIONS='--import tsx/esm' oxlint --disable-nested-config",
    "lint:fix": "NODE_OPTIONS='--import tsx/esm' oxlint --disable-nested-config --fix",
    "format": "oxfmt --write",
    "format-check": "oxfmt --check",
    "ci": "pnpm typecheck && pnpm lint && pnpm test -- --run && pnpm format-check",
    "lint-staged": "lint-staged",
    "prepare": "husky && effect-language-service patch"
  },
  "dependencies": {
    "alchemy": "2.0.0-beta.57",
    "effect": "4.0.0-beta.85",
    "fast-check": "^4.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@distilled.cloud/cloudflare": "0.26.1",
    "@effect/language-service": "^0.86.6",
    "@effect/platform-node": "4.0.0-beta.85",
    "@effect/vitest": "4.0.0-beta.85",
    "@oxlint/plugins": "^1.73.0",
    "@types/node": "^26.1.1",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.ts": [
      "oxfmt --write",
      "oxlint --fix"
    ]
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "workerd"
    ]
  }
}
