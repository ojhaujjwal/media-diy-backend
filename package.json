{
  "name": "ts-starter",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "alchemy dev",
    "deploy": "alchemy deploy",
    "lint": "NODE_OPTIONS='--import tsx/esm' oxlint --disable-nested-config",
    "lint:fix": "NODE_OPTIONS='--import tsx/esm' oxlint --disable-nested-config --fix",
    "format": "oxfmt --write",
    "format-check": "oxfmt --check",
    "ci": "pnpm typecheck && pnpm lint && pnpm test -- --run && pnpm format-check",
    "lint-staged": "lint-staged",
    "prepare": "husky && effect-language-service patch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "@aws-sdk/s3-request-presigner": "^3.1061.0",
    "alchemy": "2.0.0-beta.51",
    "effect": "^4.0.0-beta.76",
    "fast-check": "^3.18.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260604.1",
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "^4.0.0-beta.76",
    "@oxlint/plugins": "^1.68.0",
    "@types/node": "^22.0.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  },
  "lint-staged": {
    "*.ts": [
      "oxfmt --write",
      "oxlint --fix"
    ]
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
