{
  "name": "ts-starter",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "nodemon --exec 'tsx --env-file=.env' --watch src/ src/http/run-server.ts",
    "upload": "tsx src/cli/upload-media-client.ts",
    "lint": "NODE_OPTIONS='--import tsx/esm' oxlint --disable-nested-config",
    "lint:fix": "NODE_OPTIONS='--import tsx/esm' oxlint --disable-nested-config --fix",
    "format": "oxfmt --write",
    "format-check": "oxfmt --check",
    "ci": "pnpm typecheck && pnpm lint && pnpm test -- --run && pnpm format-check",
    "lint-staged": "lint-staged",
    "prepare": "husky && effect-language-service patch"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1060.0",
    "@effect-aws/client-dynamodb": "^2.0.0-beta.4",
    "@effect-aws/client-s3": "^2.0.0-beta.4",
    "@effect/platform-node": "^4.0.0-beta.76",
    "effect": "^4.0.0-beta.76",
    "fast-check": "^3.18.0",
    "minio": "^8.0.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "^4.0.0-beta.76",
    "@oxlint/plugins": "^1.68.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nodemon": "^3.1.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  },
  "lint-staged": {
    "*.ts": [
      "oxfmt --write",
      "oxlint --fix"
    ]
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
