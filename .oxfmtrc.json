{
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "none",
  "arrowParens": "always",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.output/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/coverage/**",
    "**/repos/**",
    "**/*.gen.ts",
    "**/*.gen.tsx",
    "**/*.md"
  ]
}
